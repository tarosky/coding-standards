{
    "name": "tarosky/coding-standards",
    "description": "Tarosky Coding Standards for WordPress projects, using PHP_CodeSniffer ruleset.",
    "type": "phpcodesniffer-standard",
    "homepage": "https://github.com/tarosky/coding-standards",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Tarosky INC.",
            "email": "hi@tarosky.co.jp"
        }
    ],
    "require": {
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "sirbrillig/phpcs-variable-analysis": "^2.11",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "scripts": {
        "check-outdated": "composer outdated --direct --strict",
        "update-deps": "composer update --no-interaction --no-dev",
        "update-deps-dev": "composer update --no-interaction",
        "update-check": [
            "@check-outdated",
            "echo 'Run `composer update-deps` to update production dependencies or `composer update-deps-dev` to update all dependencies'"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "require-dev": {
        "phpcompatibility/php-compatibility": "dev-develop as 9.99.99"
    }
}
